# --- App / Env ---
ENV=dev
LOG_LEVEL=INFO

# --- Telegram Bot ---
BOT_TOKEN=123456:ABCDEF
API_BASE_URL=http://api:8000

# --- S3 / Object Storage (Yandex compatible) ---
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=pitchboost-audio
S3_ACCESS_KEY=YOUR_ACCESS_KEY
S3_SECRET_KEY=YOUR_SECRET_KEY
S3_PRESIGN_EXPIRES=600
AUDIO_KEY_STYLE=flat

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_IN=aith.messages.processing      # requests-topic alternative
KAFKA_TOPIC_OUT=aith.messages.result         # responses-topic alternative
KAFKA_CLIENT_ID=pitchboost-gateway
KAFKA_GROUP_ID=ai-gateway-bot

# --- DB (Postgres) ---
DB_HOST=db
DB_PORT=5432
DB_USER=pitchboost
DB_PASSWORD=change_me
DB_NAME=pitchboost

# --- Free tier ---
FREE_CREDITS=5

# --- Audio validation ---
AUDIO_MAX_SECONDS=300
AUDIO_MAX_CONTENT_LENGTH=52428800   # 50 MB safety cap for downloads
