# --- App / Env ---
ENV=dev
LOG_LEVEL=INFO

# --- Telegram Bot ---
BOT_TOKEN=123456:ABCDEF
API_BASE_URL=http://api:8000

# --- S3 / Object Storage (Yandex compatible) ---
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=pitchboost-audio
S3_ACCESS_KEY=YOUR_ACCESS_KEY
S3_SECRET_KEY=YOUR_SECRET_KEY
S3_PRESIGN_EXPIRES=600
AUDIO_KEY_STYLE=flat

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_IN=aith.messages.processing
KAFKA_TOPIC_OUT=aith.messages.result
KAFKA_CLIENT_ID=pitchboost-gateway
KAFKA_GROUP_ID=ai-gateway-bot
